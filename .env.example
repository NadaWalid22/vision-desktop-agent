# Vision Desktop Agent — Environment Configuration
# Copy to .env and fill in values

# ─── Grounding ────────────────────────────────────────────────────────────────
# CLIP model variant: "ViT-B/32" | "ViT-L/14" | "ViT-B/16"
CLIP_MODEL=ViT-B/32

# Minimum confidence threshold to accept a detection (0.0–1.0)
GROUNDING_CONFIDENCE_THRESHOLD=0.25

# Maximum region proposals to evaluate per screenshot
GROUNDING_MAX_PROPOSALS=200

# ─── Automation ───────────────────────────────────────────────────────────────
# Delay (seconds) between pyautogui actions — increase on slow machines
ACTION_DELAY=0.3

# Number of times to retry a failed detection before raising
DETECTION_RETRIES=3

# Output directory for saved Notepad files
NOTEPAD_OUTPUT_DIR=C:/Users/Public/Desktop/tjm-project

# ─── API ──────────────────────────────────────────────────────────────────────
JSONPLACEHOLDER_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT=10
API_RETRIES=3

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
